#!/usr/bin/env bash
set -e
if [[ ! -d "/home/vrash/github/vrashabh-sontakke/rust-fullstack" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/home/vrash/github/vrashabh-sontakke/rust-fullstack")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/home/vrash/github/vrashabh-sontakke/rust-fullstack" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/home/vrash/github/vrashabh-sontakke/rust-fullstack/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/home/vrash/github/vrashabh-sontakke/rust-fullstack/.envrc" "/home/vrash/github/vrashabh-sontakke/rust-fullstack/.direnv"/*.rc
